RewriteEngine On

# If the request is not for an existing file or directory in dist/
RewriteCond %{REQUEST_URI} ^/parc/(.*)$
RewriteCond %{DOCUMENT_ROOT}/parc/dist/%1 -f [OR]
RewriteCond %{DOCUMENT_ROOT}/parc/dist/%1 -d
RewriteRule ^(.*)$ dist/$1 [L]

# Default: serve dist/index.html for all other requests (SPA fallback)
RewriteRule ^(?!dist/)(.*)$ dist/$1 [L]

# If no file found in dist, serve dist/index.html
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ dist/index.html [L]
